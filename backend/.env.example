# OpenRouter Configuration (official Python SDK: pose-variants SSE — images + outlines)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Mubit (required — app startup fails if missing or blank)
MUBIT_API_KEY=
# Optional overrides (defaults are fine for hosted Mubit)
# MUBIT_ENDPOINT=https://api.mubit.ai
# MUBIT_TRANSPORT=auto

# OpenAI Configuration (onboarding vision only — see memory_onboarding.py)
OPENAI_API_KEY=

# AI Model Configuration
AGENT_MODEL=openai/gpt-5.4-mini
IMAGE_MODEL=black-forest-labs/flux.2-pro
# Vision + JSON Schema: silhouette polygon per streamed pose (same POST /api/pose-variants SSE)
POSE_GUIDE_MODEL=google/gemini-3.1-pro-preview
# Keep low: OpenRouter reserves budget against this cap (default 2048 is enough for small JSON)
POSE_GUIDE_MAX_TOKENS=2048
# Pose-target planning agent (pydantic_ai); lower if you hit 402 "fewer max_tokens"
AGENT_MAX_TOKENS=8192

# Storage Configuration
GENERATED_TTL_SECONDS=21600

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Clerk Authentication
CLERK_SECRET_KEY=
CLERK_AUTHORIZED_PARTIES=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL Configuration
POSTGRES_DATABASE=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
