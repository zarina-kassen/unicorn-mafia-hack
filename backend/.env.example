# OpenRouter Configuration (official Python SDK: pose-variants SSE — images + outlines)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Mubit (required — app startup fails if missing or blank)
MUBIT_API_KEY=
# Optional overrides (defaults are fine for hosted Mubit)
# MUBIT_ENDPOINT=https://api.mubit.ai
# MUBIT_TRANSPORT=auto

# OpenAI Configuration (onboarding vision only — see memory_onboarding.py)
OPENAI_API_KEY=

# AI Model Configuration
# Pydantic AI pose-target planner (OpenRouter); not FLUX.
AGENT_MODEL=meta-llama/llama-3.3-70b-instruct
# Pose-variant images: FLUX on OpenRouter (try flux-schnell for max speed). Legacy: IMAGE_MODEL alias.
FAST_IMAGE_MODEL=black-forest-labs/flux.2-klein-4b
# Person-segmentation mask for pose overlay (defaults to FAST_IMAGE_MODEL if unset).
# MASK_MODEL=black-forest-labs/flux.2-klein-4b
# Vision + JSON Schema outline (fallback until mask loads; not FLUX).
POSE_GUIDE_MODEL=openai/gpt-4o-mini
# Keep low: OpenRouter reserves budget against this cap (default 2048 is enough for small JSON)
POSE_GUIDE_MAX_TOKENS=768
# Speed / size: lower = faster & smaller (JPEG reference, stored gens, vision outline)
# POSE_REFERENCE_MAX_EDGE_PX=720
# POSE_OUTLINE_VISION_MAX_EDGE_PX=512
# POSE_STORED_IMAGE_MAX_EDGE_PX=768
# POSE_JPEG_QUALITY=78
# POSE_VARIANT_IMAGE_SIZE=1K
# Pose-target planning agent (pydantic_ai); lower if you hit 402 "fewer max_tokens"
AGENT_MAX_TOKENS=8192

# Billing (SQLite ledger + Stripe Checkout). See app/billing.py for PACK_CREDITS / price env keys.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_100_CREDITS=price_...
# STRIPE_PRICE_200_CREDITS=price_...
# BILLING_DB_PATH=billing.sqlite3

# Storage Configuration
GENERATED_TTL_SECONDS=21600

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Clerk Authentication
CLERK_SECRET_KEY=
CLERK_AUTHORIZED_PARTIES=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL Configuration
POSTGRES_DATABASE=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
