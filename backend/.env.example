# Pydantic AI Gateway API key — create one at https://logfire.pydantic.dev
PYDANTIC_AI_GATEWAY_API_KEY=

# Optional overrides.
# AGENT_MODEL=gateway/openai:gpt-5.3
# ALLOWED_ORIGINS=http://localhost:5173
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# FAST_IMAGE_MODEL=black-forest-labs/flux.2-klein-4b
# HQ_IMAGE_MODEL=openai/gpt-5-image
# MASK_MODEL=black-forest-labs/flux.2-klein-4b

# Billing (SQLite ledger + Stripe Checkout). See app/billing.py for PACK_CREDITS / price env keys.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_100_CREDITS=price_...
# STRIPE_PRICE_200_CREDITS=price_...
# BILLING_DB_PATH=billing.sqlite3

# --- LinkedIn post agent (Post to LinkedIn from saved photos) ---
# Demo mode: no real LinkedIn / Devin calls; OAuth short-circuits to success.
# LINKEDIN_DEMO_MODE=true
# Uses OPENROUTER_API_KEY (same as mask extraction). When unset, vision uses deterministic local scores.
# LINKEDIN_SCORE_MODEL=openai/gpt-4o-mini   # optional OpenRouter vision model for scoring
# OPENROUTER_VISION_MODEL=...               # optional alias default for LINKEDIN_SCORE_MODEL
# DEVIN_API_KEY=                    # optional; when unset, sequencing is deterministic
# DEVIN_INVOKE_URL=https://api.devin.ai/v1/invoke
# LINKEDIN_CLIENT_ID=your_app_id
# LINKEDIN_CLIENT_SECRET=your_secret
# Link must match a redirect URL in your LinkedIn app (e.g. http://localhost:8000/api/linkedin/oauth/callback)
# LINKEDIN_REDIRECT_URI=http://localhost:8000/api/linkedin/oauth/callback
# After OAuth, we redirect the browser to this app URL:
# FRONTEND_OAUTH_LANDING=http://localhost:5173/
# LINKEDIN_DB_PATH=linkedin.sqlite3
