# Pydantic AI Gateway API key — create one at https://logfire.pydantic.dev
PYDANTIC_AI_GATEWAY_API_KEY=
OPENAI_API_KEY=

# Clerk authentication — get keys from https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_...
# Comma-separated list of origins allowed to make authenticated requests
CLERK_AUTHORIZED_PARTIES=http://localhost:5173,http://127.0.0.1:5173

# Optional overrides.
# AGENT_MODEL=gateway/openai:gpt-5.3
# ALLOWED_ORIGINS=http://localhost:5173
# MUBIT_API_KEY=mbt_...
# MUBIT_ENDPOINT=https://api.mubit.ai
# MUBIT_TRANSPORT=auto
# IMAGE_MODEL=gpt-image-1
# IMAGE_SIZE=1024x1536
# IMAGE_QUALITY=medium
# IMAGE_INPUT_FIDELITY=high
# GENERATED_TTL_SECONDS=21600

