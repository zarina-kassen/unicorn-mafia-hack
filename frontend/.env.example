# Clerk publishable key — get it from https://dashboard.clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
#
# In Clerk Dashboard → Paths, set Sign-in URL to /sign-in and Sign-up URL to /sign-up.
# Add allowed redirect origins for each dev URL (e.g. http://localhost:5173 and your ngrok host).

# Set to 1 when you use ngrok (or similar) to expose the Vite dev server.
# Disables HMR so a dropped dev WebSocket does not trigger a full page reload.
# VITE_TUNNEL=1
