# Base URL of the FastAPI backend as reachable from the phone.
# On a real device: use your dev machine's LAN IP, e.g.:
#   EXPO_PUBLIC_API_BASE_URL=http://192.168.1.42:8000
# On an Android emulator: EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8000
# On an iOS simulator:    EXPO_PUBLIC_API_BASE_URL=http://localhost:8000
#
# Leave empty to run the app offline; MediaPipe + overlay + templates still
# work, only the backend-generated guidance is disabled and the overlay falls
# back to the locally-matched template's guidance string.
EXPO_PUBLIC_API_BASE_URL=http://10.0.1.209:8000
